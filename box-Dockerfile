FROM python:3.11-slim
ENV LANG C.UTF-8
ENV LC_ALL C.UTF-8
ENV PYTHONUNBUFFERED=1
ENV DEBIAN_FRONTEND noninteractive
RUN apt-get update && apt-get install -y build-essential curl unzip wget jq xvfb firefox-esr tor iptables-persistent iptables net-tools supervisor tcpdump libtesseract-dev libleptonica-dev tesseract-ocr
COPY box-requirements.txt .
RUN pip install -r box-requirements.txt
RUN apt-get update && apt-get install -y chromium chromium-driver && \
    ln -s /usr/bin/chromium /usr/bin/google-chrome
COPY ./box/supervisord.conf /etc/supervisor/conf.d/supervisord.conf
RUN mkdir /output
ADD ./box ./box
WORKDIR box
ENTRYPOINT ["python", "run.py"]